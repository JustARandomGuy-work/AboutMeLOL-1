{
  "name": "about-me-lol",
  "version": "1.0.0",
  "description": "About Me.LOL full-stack application with direct tsx execution",
  "type": "module",
  "main": "backend/src/index.ts",
  "scripts": {
    "dev": "node build-frontend.js && tsx backend/src/index.ts",
    "build": "node build-frontend.js",
    "start": "npx tsx --experimental-specifier-resolution=node backend/src/index.ts",
    "lint": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.38.4",
    "@vercel/postgres": "^0.5.1",
    "aws-sdk": "^2.1500.0",
    "axios": "^1.6.2",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "drizzle-orm": "^0.29.3",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.1.0",
    "ioredis": "^5.3.2",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^6.9.7",
    "pg": "^8.11.3",
    "uuid": "^9.0.1",
    "zod": "^3.22.4",
    "tsx": "^4.7.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.10.0",
    "@types/nodemailer": "^8.0.1",
    "@types/pg": "^8.20.0",
    "drizzle-kit": "^0.20.13",
    "typescript": "^5.2.2"
  },
  "engines": {
    "node": ">=18.0.0"
  }
